# Locafy Frontend — Environment Variables
# Copy to .env.local for local dev. Set the same keys in Vercel → Settings → Environment Variables.

# ─── Required ─────────────────────────────────────────────────────────────────

# NextAuth encryption secret — generate: openssl rand -base64 32
NEXTAUTH_SECRET=

# Google OAuth (same client as backend GOOGLE_CLIENT_ID)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Spring Boot API (production: https://api.locafy.in)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080

# ─── Recommended for production ───────────────────────────────────────────────

# Optional on Vercel if trustHost is enabled (auth.ts). Set for custom domain:
# NEXTAUTH_URL=https://locafy.in

# Mapbox public token — maps + live delivery tracking
NEXT_PUBLIC_MAPBOX_TOKEN=

# Razorpay public key (test or live)
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# Cloudinary cloud name (URL construction)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
